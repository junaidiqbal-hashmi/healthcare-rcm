```gitignore
# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------------------------
# uv
# ------------------------------------------------------------------------------
.python-version

# Keep uv.lock committed for reproducible builds
# uv.lock

# ------------------------------------------------------------------------------
# Build / Distribution
# ------------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# IDEs
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/

# ------------------------------------------------------------------------------
# OS Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------------------------
.env
.env.*

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
data/logs/

# ------------------------------------------------------------------------------
# Airflow
# ------------------------------------------------------------------------------
airflow.cfg
airflow.db
airflow-webserver.pid

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
postgres_data/

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------------------------
# Data Files
# ------------------------------------------------------------------------------

# Original downloaded datasets
data/source/

# Temporary files
data/archive/

# Generated CSVs
data/raw/

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------
*.tmp
*.bak
*.swp

# ------------------------------------------------------------------------------
# Kaggle
# ------------------------------------------------------------------------------
kaggle.json

# ------------------------------------------------------------------------------
# Secrets
# ------------------------------------------------------------------------------
secrets/
credentials/
```
